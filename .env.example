# Copy to `.env` (gitignored) and edit only if you change the docker-compose
# port mapping. Defaults match docker-compose.yml.

# Dev database — used by the running app.
DATABASE_URL="postgresql://dyd:dyd@localhost:5433/dyd?schema=public"

# Test database — used by automated seed-smoke tests. Lives on the same
# Postgres container as DATABASE_URL but a separate logical database.
DATABASE_URL_TEST="postgresql://dyd:dyd@localhost:5433/dyd_test?schema=public"

# Optional: provider key for live agent runs. Leave unset to ship on the
# deterministic no-key fallback path. NEVER prefix with NEXT_PUBLIC_.
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5
